# Source SoundFonts for the GM converter (#193 2b). Large (~150MB), never committed.
# Generate with scripts/build-gm-instruments.mjs; the working copy lives in soundfonts/.
*.sf2
*.sf3
soundfonts/

# Generated GM instrument assets (#193 2b). Large; produced from the .sf2 by the
# converter. The FULL set is kept local (full-quality) / served from a CDN later —
# NOT committed. The picker degrades gracefully when an asset is absent.
public/instruments/gm/**/*.json

# ...EXCEPT the committed "lite" set (#193): the curated 21 instruments at 22.05kHz
# built by `node scripts/build-gm-instruments.mjs --profile lite`, so clones/deploys
# have sound with no hosting. Keep this list in sync with LITE_PROGRAMS in the script.
!public/instruments/gm/0000.json
