soundfonts/

# Generated GM instrument assets (#193 2b). Large; produced from the .sf2 by the
# converter and kept local (full-quality) / served from a CDN later — NOT committed.
# The picker degrades gracefully when an asset is absent. README stays tracked.
public/instruments/gm/**/*.json
